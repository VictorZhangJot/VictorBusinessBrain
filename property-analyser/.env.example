# --- Database -------------------------------------------------------------
# Local development uses SQLite (zero install). For production Postgres/PostGIS
# see docs/DEPLOYMENT.md (change provider in prisma/schema.prisma too).
DATABASE_URL="file:./dev.db"

# --- Session security -------------------------------------------------------
# Any long random string. Used to sign session cookies.
SESSION_SECRET="change-me-to-a-long-random-string"

# --- OneMap (Singapore Land Authority) --------------------------------------
# The address-search and basemap-tile endpoints used by this app require NO key.
# A token is only needed for premium OneMap services (routing etc.) - unused here.

# --- URA Data Service API ---------------------------------------------------
# Register (free) at https://www.ura.gov.sg/maps/api/ to receive an access key.
# The adapter exchanges the key for a daily token automatically.
# IMPORTANT: confirm the exact service id for commercial transactions in the
# documentation shown to you after registration, and put it in URA_COMM_SERVICE.
URA_ACCESS_KEY=""
URA_COMM_SERVICE=""

# --- data.gov.sg ------------------------------------------------------------
# The generic datastore API needs no key for public datasets. Find a dataset id
# (looks like d_xxxxxxxxxxxx) in the catalogue at https://data.gov.sg/datasets
# and paste it here to enable the connector, e.g. a commercial rental dataset.
DATAGOVSG_DATASET_ID=""

# --- App defaults -----------------------------------------------------------
APP_TIMEZONE="Asia/Singapore"
APP_CURRENCY="SGD"
