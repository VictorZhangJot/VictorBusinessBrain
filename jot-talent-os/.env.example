# Copy this file to ".env" (same folder) and fill in real values there.
# ".env" is git-ignored — it will never be committed or leave this machine.
# Restart the server (close and reopen "Start TalentOS.bat") after editing.

# Manatal: Administration -> Features -> Open API -> Generate new token
MANATAL_API_TOKEN=

# Optional: only needed if you want the Assistant's free-form questions
# answered by Claude instead of just the built-in commands.
ANTHROPIC_API_KEY=
